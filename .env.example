# =============================================================
# .env.example — File mẫu chứa các biến môi trường cần thiết
# HƯỚNG DẪN: Copy file này, đổi tên thành ".env" và điền mật khẩu của bạn
# =============================================================

# Mật khẩu SA (Ít nhất 8 ký tự, gồm Hoa, Thường, Số, Ký tự đặc biệt)
# Ví dụ: StudySync@Strong2026!
SA_PASSWORD=YourStrongPassword123!

# Chuỗi bí mật để tạo token (Nên dài trên 32 ký tự)
JWT_SECRET=Copy_And_Paste_A_Long_Random_String_Here

# Thông tin Cloudinary (Nếu có)
CLOUDINARY_CLOUD_NAME=your_name
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret
